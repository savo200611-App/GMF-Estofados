# GMF Estofados - variaveis de ambiente
# Copie este arquivo para .env.local e preencha. NUNCA commitar .env.local.

# Supabase (painel: Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service_role: USO EXCLUSIVO no servidor (Server Actions / Route Handlers).
# NUNCA prefixar com NEXT_PUBLIC_. NUNCA expor no front.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (envio de e-mail de orcamento/pedido) - fase de documentos
RESEND_API_KEY=
